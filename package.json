{
  "name": "8space-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.53.3"
  },
  "scripts": {
    "dev": "node scripts/dev-all.mjs",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:landing": "npm run dev -w packages/landing",
    "dev:app": "npm run dev -w packages/app",
    "dev:swagger": "python3 -m http.server 55027 --bind 127.0.0.1 --directory docs/api",
    "build:landing": "npm run build -w packages/landing",
    "build:app": "npm run build -w packages/app",
    "build": "npm run build:app && cp -r packages/app/dist/. packages/landing/public/app && npm run build:landing",
    "vercel-build": "npm run build:app && cp -r packages/app/dist/. packages/landing/public/app && npm run build:landing"
  }
}
